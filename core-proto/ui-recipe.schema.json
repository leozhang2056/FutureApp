{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://futureapp.dev/schemas/ui-recipe.v0.json",
  "title": "UiRecipe",
  "type": "object",
  "required": ["title", "components"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "ttsSummary": {
      "type": "string"
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/textBlock" },
          { "$ref": "#/$defs/weatherCard" },
          { "$ref": "#/$defs/reminderCard" },
          { "$ref": "#/$defs/actionButton" }
        ]
      }
    }
  },
  "$defs": {
    "textBlock": {
      "type": "object",
      "required": ["type", "text"],
      "properties": {
        "type": { "const": "text_block" },
        "text": { "type": "string" }
      },
      "additionalProperties": false
    },
    "weatherCard": {
      "type": "object",
      "required": ["type", "city", "temp", "condition"],
      "properties": {
        "type": { "const": "weather_card" },
        "city": { "type": "string" },
        "temp": { "type": "string" },
        "condition": { "type": "string" }
      },
      "additionalProperties": false
    },
    "reminderCard": {
      "type": "object",
      "required": ["type", "text", "time"],
      "properties": {
        "type": { "const": "reminder_card" },
        "text": { "type": "string" },
        "time": { "type": "string" }
      },
      "additionalProperties": false
    },
    "actionButton": {
      "type": "object",
      "required": ["type", "label", "action"],
      "properties": {
        "type": { "const": "action_button" },
        "label": { "type": "string" },
        "action": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
